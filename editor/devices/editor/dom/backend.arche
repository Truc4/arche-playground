/// DOM backend for the `editor` device — merged under `[select] editor = "dom"`. No C shim: `editor_be_open`
/// stays undefined and becomes a wasm IMPORT the JS host (dom/host.js, shipped with the device + collected by
/// `arche build --arch=wasm32`) fulfils by creating a native <textarea>. The browser does all the editing.
#module
#foreign
editor_be_open :: proc();

/// Open the editing surface.
open :: system eff {
  editor_be_open()();
}
